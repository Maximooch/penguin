# Penguin Environment Configuration
# Copy this to .env and fill in your values
# ==============================
# LLM API Keys (Choose one or more)
# ==============================
# OpenRouter (recommended for latest models)
OPENROUTER_API_KEY=sk-or-...
# OpenAI
OPENAI_API_KEY=sk-...
# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# ==============================
# Core Configuration
# ==============================
PENGUIN_DEFAULT_MODEL=moonshotai/kimi-k2.5
PENGUIN_DEFAULT_PROVIDER=openrouter
PENGUIN_CLIENT_PREFERENCE=openrouter
PENGUIN_CORS_ORIGINS=*
PENGUIN_DEBUG=1
PENGUIN_WORKSPACE=/workspace
# Link-managed inference (required only when Link supplies link_execution)
# The token must equal Link's LINK_INTERNAL_SERVICE_SECRET. It authenticates
# Penguin as a service; workspace/user/session/run identity remains per request.
LINK_INFERENCE_BASE_URL=http://localhost:3001/api/v1
LINK_INFERENCE_SERVICE_TOKEN=
LINK_INFERENCE_SERVICE_NAME=penguin
LINK_INFERENCE_PROTOCOL=responses
# ==============================
# GitHub Integration (Optional)
# ==============================
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_REPOSITORY=owner/repo
# GITHUB_TOKEN=  # Alternative to App auth
# ==============================
# Database (Optional - for future use)
# ==============================
DATABASE_URL=postgresql://penguin:penguin@postgres:5432/penguin
REDIS_URL=redis://redis:6379/0
# ==============================
# Gateway Configuration (K8s only)
# ==============================
GATEWAY_OAUTH2_CLIENT_ID=
GATEWAY_OAUTH2_CLIENT_SECRET=
GATEWAY_OAUTH2_ISSUER_URL=https://auth.example.com
